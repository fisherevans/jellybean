#!/usr/bin/env bash
# jb - local Jellybean daemon controller.
#
# Reads secrets from the macOS Keychain (prefix "jellybean.<KEY>") so the
# user doesn't fumble with env vars and Claude can drive start/stop/status
# without ever touching plaintext secrets in the shell history.
#
# Usage:
#   jb setup            interactive first-time secret entry
#   jb start            launch as a background daemon
#   jb stop             stop the running daemon
#   jb restart          stop + start
#   jb status           is it running, and is /api/health green
#   jb logs [-f]        show recent logs (or -f to follow)
#   jb build            build web apps + go binary
#   jb dev              foreground go run + open both vite dev servers
#   jb keychain set K V store a value in the keychain
#   jb keychain get K   print a value (use sparingly; secrets in plaintext)
#   jb keychain list    list keys (no values)
#   jb keychain rm K    delete a key
#   jb env              print the env that would be passed (values redacted)
#   jb auth-setup       store dev login credentials (username + password) in keychain
#   jb auth             mint a session cookie from the stored credentials
#   jb api METHOD PATH [body-json]  authenticated request via the cookie
#   jb kid-login NAME   log a kid in via /api/kids/auth/login; prompts for
#                       Jellyfin username + password, stores them under
#                       jellybean.KID_<NAME>_USER/_PASS, and caches the
#                       resulting bearer token at .run/kid-token-NAME.json
#                       (mode 600). NAME is a label you pick, e.g. "dex".
#   jb kid-list         list known kid labels (no credentials)
#   jb kid-rm NAME      delete stored credentials + cached token + device id
#   jb kapi NAME METHOD PATH [body-json]
#                       authenticated kids-API request as the named kid;
#                       sends Authorization: Bearer <token>, X-Jellyfin-User-Id,
#                       and X-Jellybean-DeviceId (DeviceId persisted at
#                       .run/kid-device-NAME so calls from the same label
#                       show up as one Jellyfin session). Re-auths once on
#                       401 if stored creds are present.
#   jb e2e [pw-args]    run the Playwright UI suite (uses keychain creds)
#   jb help             this text
#
# Modes:
#   JB_MODE=binary  (default) - run the compiled Go binary
#   JB_MODE=docker            - run via docker compose -f docker-compose.dev.yml
#
# Behavior of "start": refuses to launch if a daemon is already running.
# Use "restart" to pick up code changes. Builds the binary on demand if it
# is missing or older than any source file (binary mode only).

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/jellybean.pid"
LOG_FILE="$RUN_DIR/jellybean.log"
BIN_PATH="$RUN_DIR/jellybean"
COOKIE_FILE="$RUN_DIR/cookie.txt"
KC_PREFIX="jellybean."
JB_MODE="${JB_MODE:-binary}"

mkdir -p "$RUN_DIR"

# Resolved lazily from keychain or env.
get_port() {
    local p
    p="$(kc_get JELLYBEAN_PORT 2>/dev/null || true)"
    echo "${p:-${JELLYBEAN_PORT:-8080}}"
}

# --- keychain helpers ----------------------------------------------------

kc_set() {
    local key="$1" val="$2"
    security add-generic-password \
        -a "$USER" -s "${KC_PREFIX}${key}" -w "$val" -U >/dev/null
}

kc_get() {
    local key="$1"
    security find-generic-password \
        -a "$USER" -s "${KC_PREFIX}${key}" -w 2>/dev/null
}

kc_has() {
    kc_get "$1" >/dev/null 2>&1
}

kc_rm() {
    local key="$1"
    security delete-generic-password \
        -a "$USER" -s "${KC_PREFIX}${key}" >/dev/null 2>&1 || true
}

kc_list() {
    # Items are dumped with their service in line order; grep on the prefix.
    security dump-keychain 2>/dev/null \
        | awk -F\" -v p="$KC_PREFIX" '
            $2 == "svce" && index($4, p) == 1 { print substr($4, length(p)+1) }
        ' \
        | sort -u
}

# --- env assembly --------------------------------------------------------

REQUIRED_KEYS=(
    JELLYFIN_URL
    JELLYFIN_API_KEY
    JELLYBEAN_SESSION_SECRET
)

OPTIONAL_KEYS=(
    JELLYBEAN_PORT
    JELLYBEAN_DB_PATH
    JELLYBEAN_JELLYFIN_TAG_MIRROR
)

# Print "KEY=value" lines for everything in the keychain, plus a sane
# default for JELLYBEAN_ENV=dev. Used by start (eval'd) and env (redacted).
collect_env() {
    local k v
    for k in "${REQUIRED_KEYS[@]}" "${OPTIONAL_KEYS[@]}"; do
        if v="$(kc_get "$k")"; then
            printf '%s=%s\n' "$k" "$v"
        fi
    done
    # Defaults for things we want set even if the user hasn't put them in
    # the keychain.
    if ! kc_has JELLYBEAN_ENV; then
        printf 'JELLYBEAN_ENV=%s\n' "${JELLYBEAN_ENV:-dev}"
    fi
    if ! kc_has JELLYBEAN_PORT; then
        printf 'JELLYBEAN_PORT=%s\n' "$(get_port)"
    fi
}

assert_required() {
    local missing=()
    local k
    for k in "${REQUIRED_KEYS[@]}"; do
        kc_has "$k" || missing+=("$k")
    done
    if (( ${#missing[@]} > 0 )); then
        echo "missing required keychain entries:" >&2
        for k in "${missing[@]}"; do echo "  - ${KC_PREFIX}${k}" >&2; done
        echo >&2
        echo "Run 'jb setup' to enter them." >&2
        exit 1
    fi
}

# --- pid / process helpers ----------------------------------------------

pid_is_running() {
    local pid="$1"
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

read_pid() {
    [[ -f "$PID_FILE" ]] || { echo ""; return; }
    cat "$PID_FILE"
}

wait_for_health() {
    local timeout="${1:-15}"
    local elapsed=0
    local port
    port="$(get_port)"
    while (( elapsed < timeout )); do
        if curl -fsS "http://127.0.0.1:${port}/api/health" >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    return 1
}

# --- subcommand implementations ------------------------------------------

cmd_setup() {
    echo "Jellybean dev setup. Stores values in the macOS Keychain under"
    echo "prefix '${KC_PREFIX}'. Re-run anytime to update."
    echo

    local k cur new
    for k in JELLYFIN_URL JELLYFIN_API_KEY; do
        cur=""
        if kc_has "$k"; then cur=" (currently set)"; fi
        printf '%s%s: ' "$k" "$cur"
        if [[ "$k" == "JELLYFIN_API_KEY" ]]; then
            stty -echo
            read -r new
            stty echo
            echo
        else
            read -r new
        fi
        if [[ -n "$new" ]]; then
            kc_set "$k" "$new"
            echo "  saved."
        else
            echo "  (unchanged)"
        fi
    done

    if ! kc_has JELLYBEAN_SESSION_SECRET; then
        kc_set JELLYBEAN_SESSION_SECRET "$(openssl rand -hex 32)"
        echo "Generated and stored JELLYBEAN_SESSION_SECRET."
    fi

    echo
    echo "Done. Try: jb start"
}

cmd_env() {
    # Redacted view: prints keys with their lengths instead of values.
    local line k v
    while IFS= read -r line; do
        k="${line%%=*}"; v="${line#*=}"
        case "$k" in
            JELLYFIN_API_KEY|JELLYBEAN_SESSION_SECRET)
                printf '%s=<redacted, %d chars>\n' "$k" "${#v}"
                ;;
            *)
                printf '%s=%s\n' "$k" "$v"
                ;;
        esac
    done < <(collect_env)
}

cmd_keychain() {
    case "${1:-}" in
        set)
            [[ $# -ge 3 ]] || { echo "usage: jb keychain set KEY VALUE" >&2; exit 2; }
            kc_set "$2" "$3"
            echo "ok"
            ;;
        get)
            [[ $# -ge 2 ]] || { echo "usage: jb keychain get KEY" >&2; exit 2; }
            kc_get "$2" || { echo "(unset)"; exit 1; }
            ;;
        rm)
            [[ $# -ge 2 ]] || { echo "usage: jb keychain rm KEY" >&2; exit 2; }
            kc_rm "$2"
            echo "ok"
            ;;
        list|"")
            kc_list
            ;;
        *)
            echo "unknown keychain subcommand: $1" >&2
            exit 2
            ;;
    esac
}

needs_build() {
    [[ ! -x "$BIN_PATH" ]] && return 0
    # Rebuild if any source file (Go, SQL, web src, web build config) OR
    # an already-built dist file is newer than the binary. The Go binary
    # embeds web/{admin,kids}/dist via go:embed, so a web src edit needs
    # `npm run build` followed by `go build`; cmd_start runs both via
    # build_web + build_go when this returns true.
    #
    # We intentionally include web/*/src files: when the kid client is
    # being tested on a real TV (sideloaded APK pointed at this daemon),
    # vite dev-server HMR isn't in play - the WebView fetches the
    # embedded bundle from the Go binary.
    local newer
    newer=$(find . \
        -path ./.run -prune -o \
        -path ./node_modules -prune -o \
        -path '*/node_modules' -prune -o \
        -type f \( \
            -name '*.go' -o \
            -name '*.sql' -o \
            -name '*.tsx' -o \
            -name '*.ts' -o \
            -name '*.css' -o \
            -name '*.html' -o \
            -name 'package.json' -o \
            -name 'vite.config.*' -o \
            -path '*/dist/*' \
        \) \
        -newer "$BIN_PATH" -print 2>/dev/null | head -n1)
    [[ -n "$newer" ]]
}

build_web() {
    if [[ ! -d "$ROOT_DIR/web/admin/node_modules" ]]; then
        ( cd "$ROOT_DIR/web/admin" && npm ci --no-audit --no-fund )
    fi
    if [[ ! -d "$ROOT_DIR/web/kids/node_modules" ]]; then
        ( cd "$ROOT_DIR/web/kids" && npm ci --no-audit --no-fund )
    fi
    ( cd "$ROOT_DIR/web/admin" && npm run build )
    ( cd "$ROOT_DIR/web/kids" && npm run build )
}

build_go() {
    ( cd "$ROOT_DIR" && go build -o "$BIN_PATH" ./cmd/jellybean )
}

cmd_build() {
    build_web
    build_go
    echo "built: $BIN_PATH"
}

cmd_start() {
    assert_required

    case "$JB_MODE" in
        binary) start_binary ;;
        docker) start_docker ;;
        *) echo "unknown JB_MODE: $JB_MODE" >&2; exit 2 ;;
    esac
}

start_binary() {
    local pid
    pid="$(read_pid)"
    if pid_is_running "$pid"; then
        echo "already running (pid $pid)"
        return 0
    fi

    if needs_build; then
        echo "building..."
        build_web
        build_go
    fi

    # Build the env via collect_env and exec the binary detached. We use
    # "env -i" + explicit pass-through so the daemon doesn't inherit any
    # noisy parent vars.
    local env_args=()
    while IFS= read -r line; do
        env_args+=("$line")
    done < <(collect_env)

    : > "$LOG_FILE"  # truncate previous log
    # cd to ROOT_DIR so the daemon resolves the default JELLYBEAN_DB_PATH
    # ("./jellybean.db") relative to the repo root, not whatever directory
    # the caller happened to be in.
    (
        cd "$ROOT_DIR" || exit 1
        nohup env -i \
            HOME="$HOME" \
            PATH="$PATH" \
            TMPDIR="${TMPDIR:-/tmp}" \
            "${env_args[@]}" \
            "$BIN_PATH" \
            >>"$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
    )
    pid="$(cat "$PID_FILE")"

    if wait_for_health 15; then
        echo "started (pid $pid, port $(get_port)). logs: $LOG_FILE"
    else
        echo "started (pid $pid) but /api/health did not respond in 15s."
        echo "tail of log:"
        tail -n 20 "$LOG_FILE" >&2 || true
        return 1
    fi
}

start_docker() {
    local env_args=() line
    while IFS= read -r line; do
        env_args+=("$line")
    done < <(collect_env)
    ( cd "$ROOT_DIR" && env -i HOME="$HOME" PATH="$PATH" "${env_args[@]}" \
        docker compose -f docker-compose.dev.yml up -d --build )
    if wait_for_health 60; then
        echo "started (docker). logs: jb logs"
    else
        echo "started but /api/health did not respond in 60s; check 'jb logs'"
        return 1
    fi
}

cmd_stop() {
    case "$JB_MODE" in
        binary) stop_binary ;;
        docker) stop_docker ;;
        *) echo "unknown JB_MODE: $JB_MODE" >&2; exit 2 ;;
    esac
}

stop_binary() {
    local pid
    pid="$(read_pid)"
    if ! pid_is_running "$pid"; then
        echo "not running"
        rm -f "$PID_FILE"
        return 0
    fi
    kill -TERM "$pid" 2>/dev/null || true
    local elapsed=0
    while pid_is_running "$pid"; do
        sleep 1
        elapsed=$((elapsed + 1))
        if (( elapsed > 15 )); then
            echo "did not stop after 15s, sending SIGKILL"
            kill -KILL "$pid" 2>/dev/null || true
            break
        fi
    done
    rm -f "$PID_FILE"
    echo "stopped"
}

stop_docker() {
    ( cd "$ROOT_DIR" && docker compose -f docker-compose.dev.yml down )
}

cmd_restart() {
    cmd_stop || true
    cmd_start
}

cmd_status() {
    case "$JB_MODE" in
        binary) status_binary ;;
        docker) status_docker ;;
        *) echo "unknown JB_MODE: $JB_MODE" >&2; exit 2 ;;
    esac
}

status_binary() {
    local pid healthy="no" port
    pid="$(read_pid)"
    port="$(get_port)"
    if pid_is_running "$pid"; then
        if curl -fsS "http://127.0.0.1:${port}/api/health" >/dev/null 2>&1; then
            healthy="yes"
        fi
        echo "running"
        echo "  pid:       $pid"
        echo "  port:      $port"
        echo "  healthy:   $healthy"
        echo "  log:       $LOG_FILE"
        return 0
    fi
    echo "not running"
    if [[ -f "$PID_FILE" ]]; then rm -f "$PID_FILE"; fi
    return 1
}

status_docker() {
    ( cd "$ROOT_DIR" && docker compose -f docker-compose.dev.yml ps )
}

cmd_logs() {
    case "$JB_MODE" in
        binary)
            if [[ "${1:-}" == "-f" ]]; then
                tail -f "$LOG_FILE"
            else
                tail -n 100 "$LOG_FILE"
            fi
            ;;
        docker)
            ( cd "$ROOT_DIR" && docker compose -f docker-compose.dev.yml logs --tail 100 ${1:-} )
            ;;
    esac
}

cmd_dev() {
    assert_required
    echo "Foreground dev mode. Use ctrl-c to exit."
    echo "Vite dev servers must be started separately:"
    echo "  cd web/admin && npm run dev   # http://localhost:5173"
    echo "  cd web/kids && npm run dev    # http://localhost:5174"
    echo
    local env_args=() line
    while IFS= read -r line; do
        env_args+=("$line")
    done < <(collect_env)
    cd "$ROOT_DIR"
    exec env -i HOME="$HOME" PATH="$PATH" "${env_args[@]}" \
        go run ./cmd/jellybean
}

cmd_auth_setup() {
    echo "Stores Jellyfin login credentials in the macOS Keychain so the"
    echo "agent can perform authenticated API calls without prompting."
    echo "Skip this if you don't want a programmatic login path."
    echo

    local username password
    printf 'Jellyfin username (case-sensitive): '
    read -r username
    printf 'Jellyfin password: '
    stty -echo
    read -r password
    stty echo
    echo

    if [[ -z "$username" || -z "$password" ]]; then
        echo "skipped (empty input)"
        return 0
    fi
    kc_set JELLYFIN_USERNAME "$username"
    kc_set JELLYFIN_PASSWORD "$password"
    echo "saved. run 'jb auth' to mint a session cookie."
}

cmd_auth() {
    local username password port body status
    if ! username="$(kc_get JELLYFIN_USERNAME)" || [[ -z "$username" ]]; then
        echo "no JELLYFIN_USERNAME in keychain; run 'jb auth-setup' first" >&2
        exit 1
    fi
    if ! password="$(kc_get JELLYFIN_PASSWORD)" || [[ -z "$password" ]]; then
        echo "no JELLYFIN_PASSWORD in keychain; run 'jb auth-setup' first" >&2
        exit 1
    fi
    port="$(get_port)"

    body="$(jq -nc --arg u "$username" --arg p "$password" '{username: $u, password: $p}')"
    status=$(curl -sS -o /dev/null -w '%{http_code}' \
        -c "$COOKIE_FILE" \
        -H 'Content-Type: application/json' \
        -d "$body" \
        "http://127.0.0.1:${port}/api/auth/login" || echo "000")
    case "$status" in
        200)
            chmod 600 "$COOKIE_FILE" 2>/dev/null || true
            echo "authenticated as $username; cookie saved to $COOKIE_FILE"
            ;;
        401|403)
            echo "auth failed (status $status). check JELLYFIN_USERNAME/JELLYFIN_PASSWORD in keychain." >&2
            exit 1
            ;;
        429)
            echo "rate-limited (status 429). restart the daemon to clear: jb restart" >&2
            exit 1
            ;;
        *)
            echo "unexpected status $status. is the daemon running? jb status" >&2
            exit 1
            ;;
    esac
}

cmd_api() {
    local method="${1:-GET}"; shift || true
    local path="${1:-}"; shift || true
    if [[ -z "$path" ]]; then
        echo "usage: jb api METHOD PATH [body-json]" >&2
        exit 2
    fi
    if [[ ! -f "$COOKIE_FILE" ]]; then
        echo "no cookie at $COOKIE_FILE; run 'jb auth' first" >&2
        exit 1
    fi
    local port; port="$(get_port)"
    local body="${1:-}"
    local args=(-sS -X "$method" -b "$COOKIE_FILE" -c "$COOKIE_FILE")
    if [[ -n "$body" ]]; then
        args+=(-H 'Content-Type: application/json' -d "$body")
    fi
    args+=("http://127.0.0.1:${port}${path}")
    curl "${args[@]}"
    echo
}

# Per-kid keychain entries are namespaced under jellybean.KID_<NAME>_USER and
# jellybean.KID_<NAME>_PASS (Jellyfin credentials, used to mint a bearer
# token via /api/kids/auth/login). The bearer token + jellyfin user id are
# cached at .run/kid-token-<name>.json so we don't re-auth on every call.
# The label NAME is whatever the user picks; we uppercase it for the
# keychain service name and lowercase it for filenames.
kid_validate_name() {
    local name="$1"
    # Allow letters/digits/underscore/dash; reject the rest so the key
    # name can't smuggle in spaces or colons.
    if [[ ! "$name" =~ ^[A-Za-z0-9_-]+$ ]]; then
        echo "kid label must match [A-Za-z0-9_-]+ (got: $name)" >&2
        return 2
    fi
}

kid_kc_user_key() {
    local name="$1" upper
    upper="$(echo "$name" | tr '[:lower:]' '[:upper:]')"
    echo "KID_${upper}_USER"
}

kid_kc_pass_key() {
    local name="$1" upper
    upper="$(echo "$name" | tr '[:lower:]' '[:upper:]')"
    echo "KID_${upper}_PASS"
}

kid_token_file() {
    local name="$1" lower
    lower="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
    echo "$RUN_DIR/kid-token-${lower}.json"
}

kid_device_file() {
    local name="$1" lower
    lower="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
    echo "$RUN_DIR/kid-device-${lower}.txt"
}

# Persist a per-label DeviceId so repeated calls show up as one session in
# Jellyfin's activity view (matches how a real TV would behave). Writes the
# file mode-600 on first creation.
kid_get_device_id() {
    local name="$1"
    local dev_file
    dev_file="$(kid_device_file "$name")"
    if [[ -f "$dev_file" ]]; then
        cat "$dev_file"
        return 0
    fi
    local device_id
    device_id="$(uuidgen)"
    printf '%s\n' "$device_id" > "$dev_file"
    chmod 600 "$dev_file"
    printf '%s\n' "$device_id"
}

# POST to /api/kids/auth/login with $1=username $2=password. On 200, writes
# the parsed response (token + userId + ...) to $3 (mode 600) and prints
# the friendly summary. On non-200, prints the helpful error to stderr and
# returns the curl http_code.
kid_do_login() {
    local username="$1" password="$2" out_file="$3"
    local port body status_file body_file status
    port="$(get_port)"
    status_file="$(mktemp -t jb-kid-login.XXXXXX)"
    body_file="$(mktemp -t jb-kid-login.XXXXXX)"
    # shellcheck disable=SC2064
    trap "rm -f '$status_file' '$body_file'" RETURN

    body="$(jq -nc --arg u "$username" --arg p "$password" \
        '{username: $u, password: $p}')"
    status=$(curl -sS -o "$body_file" -w '%{http_code}' \
        -H 'Content-Type: application/json' \
        -d "$body" \
        "http://127.0.0.1:${port}/api/kids/auth/login" || echo "000")
    case "$status" in
        200)
            # Validate it's parseable JSON with the expected keys before
            # we commit it to disk.
            if ! jq -e '.token and .userId' "$body_file" >/dev/null 2>&1; then
                echo "login response did not contain token + userId; got:" >&2
                cat "$body_file" >&2
                echo >&2
                return 1
            fi
            # Atomic-ish write: install with mode 600.
            install -m 600 /dev/null "$out_file"
            cat "$body_file" > "$out_file"
            return 0
            ;;
        401|403)
            echo "kid login failed (status $status). check Jellyfin username/password." >&2
            cat "$body_file" >&2
            echo >&2
            return 1
            ;;
        400)
            echo "kid login rejected (status 400). is this Jellyfin user mapped to a kid in Jellybean?" >&2
            cat "$body_file" >&2
            echo >&2
            return 1
            ;;
        502|503)
            echo "kid login upstream error (status $status). is Jellyfin reachable from the daemon?" >&2
            cat "$body_file" >&2
            echo >&2
            return 1
            ;;
        000)
            echo "kid login could not reach the daemon. is it running? jb status" >&2
            return 1
            ;;
        *)
            echo "kid login unexpected status $status" >&2
            cat "$body_file" >&2
            echo >&2
            return 1
            ;;
    esac
}

cmd_kid_login() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "usage: jb kid-login NAME" >&2
        echo "  prompts for Jellyfin username + password, POSTs to" >&2
        echo "  /api/kids/auth/login, caches the bearer token under .run/." >&2
        exit 2
    fi
    kid_validate_name "$name" || exit $?

    local user_kc pass_kc
    user_kc="$(kid_kc_user_key "$name")"
    pass_kc="$(kid_kc_pass_key "$name")"

    local username password
    printf 'Jellyfin username for kid %q: ' "$name" >&2
    IFS= read -r username
    if [[ -z "$username" ]]; then
        echo "no username provided" >&2
        exit 2
    fi
    printf 'Jellyfin password (no echo): ' >&2
    stty -echo
    IFS= read -r password
    stty echo
    echo >&2
    if [[ -z "$password" ]]; then
        echo "no password provided" >&2
        exit 2
    fi

    local token_file
    token_file="$(kid_token_file "$name")"
    if ! kid_do_login "$username" "$password" "$token_file"; then
        exit 1
    fi

    # Only stash creds after a successful login so we don't keep stale ones
    # in the keychain.
    kc_set "$user_kc" "$username"
    kc_set "$pass_kc" "$password"

    # Pre-create the device id so the user can see its location in the
    # success summary.
    local device_id
    device_id="$(kid_get_device_id "$name")"

    local user_id user_name profile_name
    user_id="$(jq -r '.userId // empty' "$token_file")"
    user_name="$(jq -r '.userName // empty' "$token_file")"
    profile_name="$(jq -r '.profileName // empty' "$token_file")"
    echo "logged in kid '$name' as '${user_name:-?}' (userId ${user_id:-?}, profile ${profile_name:-?})"
    echo "  token cached:  $token_file"
    echo "  device id:     $(kid_device_file "$name")"
    echo "  creds:         $KC_PREFIX$user_kc / $KC_PREFIX$pass_kc"
}

cmd_kid_list() {
    # Filter the keychain list to KID_*_USER entries; strip the suffix to
    # get the label. Values are never printed.
    cmd_keychain list \
        | sed -n 's/^KID_\(.*\)_USER$/  \1/p' \
        | tr '[:upper:]' '[:lower:]' \
        | sort -u
}

cmd_kid_rm() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "usage: jb kid-rm NAME" >&2
        exit 2
    fi
    kid_validate_name "$name" || exit $?
    kc_rm "$(kid_kc_user_key "$name")"
    kc_rm "$(kid_kc_pass_key "$name")"
    rm -f "$(kid_token_file "$name")"
    rm -f "$(kid_device_file "$name")"
    echo "removed kid '$name'"
}

# Re-auth using stored credentials and rewrite the cached token file.
# Returns 0 on success, 1 if creds aren't stored or login fails.
kid_reauth() {
    local name="$1"
    local user_kc pass_kc username password token_file
    user_kc="$(kid_kc_user_key "$name")"
    pass_kc="$(kid_kc_pass_key "$name")"
    if ! username="$(kc_get "$user_kc")" || [[ -z "$username" ]]; then
        return 1
    fi
    if ! password="$(kc_get "$pass_kc")" || [[ -z "$password" ]]; then
        return 1
    fi
    token_file="$(kid_token_file "$name")"
    kid_do_login "$username" "$password" "$token_file"
}

cmd_kapi() {
    local name="${1:-}"; shift || true
    local method="${1:-GET}"; shift || true
    local path="${1:-}"; shift || true
    if [[ -z "$name" || -z "$path" ]]; then
        echo "usage: jb kapi NAME METHOD PATH [body-json]" >&2
        exit 2
    fi
    kid_validate_name "$name" || exit $?

    local token_file
    token_file="$(kid_token_file "$name")"
    if [[ ! -f "$token_file" ]]; then
        echo "no session for kid '$name'; run 'jb kid-login $name' first" >&2
        exit 1
    fi

    local device_id
    device_id="$(kid_get_device_id "$name")"

    local body="${1:-}"
    local port; port="$(get_port)"

    # Single-shot send; if it returns 401 and we have stored creds, re-auth
    # and try once more.
    local attempt status body_file token user_id
    body_file="$(mktemp -t jb-kapi.XXXXXX)"
    # shellcheck disable=SC2064
    trap "rm -f '$body_file'" RETURN

    for attempt in 1 2; do
        token="$(jq -r '.token // empty' "$token_file")"
        user_id="$(jq -r '.userId // empty' "$token_file")"
        if [[ -z "$token" || -z "$user_id" ]]; then
            echo "cached session for '$name' is malformed; run 'jb kid-login $name'" >&2
            exit 1
        fi

        local args=(-sS -o "$body_file" -w '%{http_code}' -X "$method"
            -H "Authorization: Bearer $token"
            -H "X-Jellyfin-User-Id: $user_id"
            -H "X-Jellybean-DeviceId: $device_id")
        if [[ -n "$body" ]]; then
            args+=(-H 'Content-Type: application/json' -d "$body")
        fi
        args+=("http://127.0.0.1:${port}${path}")
        status=$(curl "${args[@]}" || echo "000")

        if [[ "$status" == "401" && "$attempt" == "1" ]]; then
            echo "session expired; re-authenticating..." >&2
            if ! kid_reauth "$name"; then
                echo "kid session expired and re-login failed; run 'jb kid-login $name'" >&2
                exit 1
            fi
            continue
        fi
        break
    done

    cat "$body_file"
    echo
    # Propagate non-2xx as a non-zero exit so callers can tell.
    if [[ "$status" =~ ^2[0-9][0-9]$ ]]; then
        return 0
    fi
    return 1
}

cmd_e2e() {
    if ! pid_is_running "$(read_pid)"; then
        echo "daemon not running; start it first with 'jb start'" >&2
        exit 1
    fi
    if ! command -v npx >/dev/null 2>&1; then
        echo "npx not found; install Node 20+ and re-run" >&2
        exit 1
    fi
    local username password
    if ! username="$(kc_get JELLYFIN_USERNAME)" || [[ -z "$username" ]]; then
        echo "JELLYFIN_USERNAME not in keychain; run 'jb auth-setup' first" >&2
        exit 1
    fi
    if ! password="$(kc_get JELLYFIN_PASSWORD)" || [[ -z "$password" ]]; then
        echo "JELLYFIN_PASSWORD not in keychain; run 'jb auth-setup' first" >&2
        exit 1
    fi

    if [[ ! -d "$ROOT_DIR/web/admin/node_modules" ]]; then
        ( cd "$ROOT_DIR/web/admin" && npm ci --no-audit --no-fund )
    fi
    if [[ ! -d "$ROOT_DIR/web/admin/node_modules/@playwright" ]]; then
        ( cd "$ROOT_DIR/web/admin" && npx playwright install chromium )
    fi

    # Optional kid creds for tests that exercise the /player flow.
    # Stored separately so the kid bearer login works without the
    # admin path doing double duty.
    local kid_username kid_password
    kid_username="$(kc_get JELLYBEAN_KID_USERNAME 2>/dev/null || true)"
    kid_password="$(kc_get JELLYBEAN_KID_PASSWORD 2>/dev/null || true)"

    local port; port="$(get_port)"
    cd "$ROOT_DIR/web/admin"
    JB_BASE_URL="http://127.0.0.1:${port}" \
    JELLYFIN_USERNAME="$username" \
    JELLYFIN_PASSWORD="$password" \
    JELLYBEAN_KID_USERNAME="$kid_username" \
    JELLYBEAN_KID_PASSWORD="$kid_password" \
        npx playwright test "$@"
}

cmd_help() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

# --- dispatch ------------------------------------------------------------

case "${1:-help}" in
    setup)       shift; cmd_setup "$@" ;;
    start)       shift; cmd_start "$@" ;;
    stop)        shift; cmd_stop "$@" ;;
    restart)     shift; cmd_restart "$@" ;;
    status)      shift; cmd_status "$@" ;;
    logs)        shift; cmd_logs "$@" ;;
    build)       shift; cmd_build "$@" ;;
    dev)         shift; cmd_dev "$@" ;;
    env)         shift; cmd_env "$@" ;;
    keychain)    shift; cmd_keychain "$@" ;;
    auth-setup)  shift; cmd_auth_setup "$@" ;;
    auth)        shift; cmd_auth "$@" ;;
    api)         shift; cmd_api "$@" ;;
    kid-login)   shift; cmd_kid_login "$@" ;;
    kid-list)    shift; cmd_kid_list "$@" ;;
    kid-rm)      shift; cmd_kid_rm "$@" ;;
    kapi)        shift; cmd_kapi "$@" ;;
    e2e)         shift; cmd_e2e "$@" ;;
    help|-h|--help) cmd_help ;;
    *) echo "unknown command: $1" >&2; cmd_help; exit 2 ;;
esac
